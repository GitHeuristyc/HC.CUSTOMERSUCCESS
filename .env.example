# Jira
JIRA_BASE_URL=https://heuristyc.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (Supabase Auth via @supabase/ssr)
# Domain whitelist enforced in /auth/callback (anything outside this domain is rejected and signed out)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=heuristyc.com
# Optional: only used by client UI to build redirectTo; defaults to window.location.origin/auth/callback
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# Routine (Fathom MCP routine → /api/reminders/batch)
ROUTINE_API_KEY=

# Deployment
VERCEL_TOKEN=
VERCEL_TEAM_ID=
